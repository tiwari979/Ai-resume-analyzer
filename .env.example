# ============================================================
# AI Resume Analyzer — Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# JWT Secret (required - change this in production!)
JWT_SECRET=your-super-secret-jwt-key-min-32-chars-change-this

# -------------------------------------------------------
# ANTHROPIC API KEY (optional but HIGHLY recommended)
# Get yours free at: https://console.anthropic.com
# Without this: rule-based keyword matching (generic results)
# With this:    real Claude AI analysis (unique per resume)
# -------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Grafana login
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin123
